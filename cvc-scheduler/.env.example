# Safe for browser and server use. Obtain these from the Supabase project API settings.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# "review" keeps the current mock admin routes open. "enforced" requires a
# Supabase Auth session for admin routes other than the auth shell.
ADMIN_AUTH_MODE=review

# Trusted application origin used only by the unlinked server-side response-link diagnostic.
# Use http://127.0.0.1:3000 locally and an https origin in deployed environments.
RESPONSE_LINK_BASE_URL=

# Optional until a reviewed server-only operation explicitly requires it.
# Never add NEXT_PUBLIC_ to this name and never use it from browser code.
SUPABASE_SERVICE_ROLE_KEY=
