# Safe for browser and server use. Obtain these from the Supabase project API settings.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Optional until a reviewed server-only operation explicitly requires it.
# Never add NEXT_PUBLIC_ to this name and never use it from browser code.
SUPABASE_SERVICE_ROLE_KEY=
