{
  "name": "cvc-scheduler",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "preview": "next start",
    "start": "next start",
    "lint": "eslint",
    "preview:screenshots": "node scripts/capture-previews.mjs",
    "supabase:check": "node scripts/supabase-smoke.mjs",
    "test:workspace": "node --no-warnings --experimental-strip-types scripts/workspace-persistence-regression.mjs",
    "test:grants": "node --no-warnings --experimental-strip-types scripts/grants-authorization-regression.mjs",
    "test:questionnaires": "node --no-warnings --experimental-strip-types scripts/questionnaire-persistence-regression.mjs",
    "test:volunteers": "node --no-warnings --experimental-strip-types scripts/volunteer-persistence-regression.mjs",
    "test:tasks": "node --no-warnings --experimental-strip-types scripts/task-persistence-regression.mjs",
    "test:calendar-items": "node --no-warnings --experimental-strip-types scripts/calendar-item-persistence-regression.mjs",
    "test:assignments": "node --no-warnings --experimental-strip-types scripts/assignment-persistence-regression.mjs",
    "test:response-tokens": "node --conditions=react-server --no-warnings --experimental-strip-types scripts/response-token-persistence-regression.mjs",
    "test:response-route": "node scripts/response-route-valid-token-regression.mjs",
    "test:response-link": "node --conditions=react-server --no-warnings --experimental-strip-types scripts/response-link-issuance-regression.mjs",
    "test:calendar": "node scripts/calendar-regression.mjs"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.110.0",
    "lucide-react": "^1.21.0",
    "next": "16.2.7",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "playwright": "^1.61.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
